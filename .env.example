# Database
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=harmony_mcp
DB_USER=postgres
DB_POOL_MIN=1
DB_POOL_MAX=10

# NASA Earthdata Login — register at urs.earthdata.nasa.gov
EDL_USERNAME=
EDL_PASSWORD=
EARTHDATA_TOKEN=

# Providers
DATA_FETCH_MODE=auto
HARMONY_TIMEOUT_SECONDS=600
MAX_GRANULES=20
GRANULE_CONCURRENCY=4
WORKSPACE_CACHE_BYTES=524288000

# Workspace storage
WORKSPACE_STORE_PATH=/data/workspace

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
