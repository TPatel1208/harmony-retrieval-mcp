# Storage backend — `local` (default) or `s3://bucket/prefix`
EARTHDATA_STORAGE=local
# Root for the local filesystem backend (materialized Zarr/Parquet land here)
EARTHDATA_DATA_DIR=./data
# Materialization cache eviction cap (bytes); default ~5 GiB
EARTHDATA_CACHE_MAX_BYTES=5368709120

# Database (SQLAlchemy + asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/earthdata_mcp

# Worker broker (Arq / Redis)
REDIS_URL=redis://localhost:6379/0

# NASA Earthdata Login — register at urs.earthdata.nasa.gov (used from Phase 4)
EDL_USERNAME=
EDL_PASSWORD=
EARTHDATA_TOKEN=

# Logging
LOG_LEVEL=INFO
